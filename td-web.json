[{
  "name": "web",
  "image": "426222909134.dkr.ecr.sa-east-1.amazonaws.com/rds-forms-fabrica-web:latest",
  "portMappings": [{"containerPort": 3000, "protocol": "tcp"}],
  "essential": true,
  "logConfiguration": {
    "logDriver": "awslogs",
    "options": {
      "awslogs-group": "/ecs/rds-forms-fabrica-web",
      "awslogs-region": "sa-east-1",
      "awslogs-stream-prefix": "ecs",
      "awslogs-create-group": "true"
    }
  }
}]
